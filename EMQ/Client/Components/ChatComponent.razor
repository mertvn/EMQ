@using Microsoft.Extensions.Logging
@using EMQ.Shared.Quiz.Entities.Concrete
@using EMQ.Shared.Core
@using EMQ.Shared.Auth.Entities.Concrete
@using EMQ.Shared.Core.UI
@inject HttpClient _client
@inject ILogger<ChatComponent> _logger
@inject IJSRuntime _jsRuntime
@implements IDisposable

@{
    bool isChatMod = AuthStuff.HasPermission(ClientState.Session, PermissionKind.ModerateChat);
}

<ChatUserDetailComponent @ref="_modalRef" PlayerId="@(SelectedSender?.UserId ?? 0)"></ChatUserDetailComponent>

@* do not change the id because auto-focus code relies on it *@
<div id="chat" style="display: grid;
                      grid-template-columns: @(ColumnsVw)vw;
                      grid-template-rows: 66vh 100px;
                      background-color: dimgray;
                      color: white;
                      padding: 5px;
                      margin: 5px;
                      float: right;
                      position: relative;">

    <button style="position: absolute; top: 0; right: 0; border-radius: 50%; width: 20px" @onclick="@(() => { ColumnsVw = ColumnsVw < 54 ? 54 : 14; })">&lt;</button>

    <div id="chatHistory" @ref="_chatHistoryRef" style="overflow-x: visible; overflow-y: auto; word-wrap: anywhere">
        @foreach (ChatMessage chatMessage in Chat.Concat(ClientChat).OrderBy(x => x.Timestamp))
        {
            <ChatMessageComponent ChatMessage="chatMessage" IsChatMod="isChatMod" Onclick_Sender="Onclick_Sender"/>
        }
    </div>

    <div style="position: relative;">
        @if (ShowEmojiPicker)
        {
            <div class="emoji-picker-overlay" @onclick="@(() => ShowEmojiPicker = false)"></div>
            <div class="emoji-picker" @onclick:stopPropagation="true">
                <div class="emoji-picker-header">
                    <input type="text" class="emoji-search-input"
                           placeholder="Search emoji..."
                           @bind="EmojiSearchText" @bind:event="oninput"/>
                    <button class="emoji-picker-close" @onclick="@(() => ShowEmojiPicker = false)">&times;</button>
                </div>

                <div class="emoji-picker-section">
                    <div class="emoji-grid">
                        @foreach (var kvp in FilteredEmoji)
                        {
                            <button class="emoji-btn" title="@kvp.Key"
                                    @onclick="@(() => InsertEmoji(kvp.Value))">
                                @kvp.Value
                            </button>
                        }
                    </div>
                    @if (!FilteredEmoji.Any())
                    {
                        <div class="emoji-no-results">No emoji found</div>
                    }
                </div>
            </div>
        }

        <div style="display: flex; align-items: stretch;">
            <textarea
                id="chatInput" @ref="_chatInputRef"
                disabled="@(!AuthStuff.HasPermission(ClientState.Session, PermissionKind.SendChatMessage))"
                rows="4" cols="50" maxlength="@Constants.MaxChatMessageLength" placeholder="Chat"
                @bind="ChatInputText" @bind:event="oninput"
                @onkeydown="OnKeyDown" @onkeydown:preventDefault="_preventDefault"
                style="resize: none; overflow: auto; flex: 1;"></textarea>
            <button class="emoji-toggle-btn"
                    title="Emoji picker"
                    disabled="@(!AuthStuff.HasPermission(ClientState.Session, PermissionKind.SendChatMessage))"
                    @onclick="ToggleEmojiPicker">
                &#x1F600;
            </button>
        </div>
    </div>
</div>

<style>
    .emoji-toggle-btn {
        width: 36px;
        background: #4a4a4a;
        border: 1px solid #666;
        border-left: none;
        cursor: pointer;
        font-size: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s;
    }

    .emoji-toggle-btn:hover:not(:disabled) {
        background: #5a5a5a;
    }

    .emoji-toggle-btn:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    .emoji-picker-overlay {
        position: fixed;
        inset: 0;
        z-index: 99;
    }

    .emoji-picker {
        position: absolute;
        bottom: 100%;
        right: 0;
        width: 550px;
        max-height: 360px;
        background: #2b2b2b;
        border: 1px solid #555;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        z-index: 100;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .emoji-picker-header {
        display: flex;
        align-items: center;
        padding: 6px 8px;
        gap: 4px;
        border-bottom: 1px solid #444;
        background: #333;
    }

    .emoji-search-input {
        flex: 1;
        background: #3a3a3a;
        border: 1px solid #555;
        border-radius: 4px;
        color: #eee;
        padding: 4px 8px;
        font-size: 13px;
        outline: none;
    }

    .emoji-search-input::placeholder {
        color: #888;
    }

    .emoji-search-input:focus {
        border-color: #7a7aff;
    }

    .emoji-picker-close {
        background: none;
        border: none;
        color: #aaa;
        font-size: 18px;
        cursor: pointer;
        padding: 0 4px;
        line-height: 1;
    }

    .emoji-picker-close:hover {
        color: #fff;
    }

    .emoji-picker-section {
        flex: 1;
        overflow-y: auto;
        padding: 6px;
    }

    .emoji-grid {
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: 2px;
    }

    .emoji-btn {
        background: none;
        border: none;
        border-radius: 4px;
        font-size: 20px;
        cursor: pointer;
        padding: 4px;
        line-height: 1.2;
        transition: background 0.1s;
    }

    .emoji-btn:hover {
        background: #444;
    }
</style>
